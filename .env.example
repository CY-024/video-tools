ARK_API_KEY=你的 API Key
ARK_MODEL_ID=模型 ID
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions
API_PORT=8787

# 本地 MP4 解说提取
# 不填写时，会先找系统 PATH 里的 ffmpeg/ffprobe。
# Windows 下找不到时，会自动下载到 data/tools/ffmpeg/。
FFMPEG_PATH=
FFPROBE_PATH=
FFMPEG_DOWNLOAD_URL=https://www.gyan.dev/ffmpeg/builds/ffmpeg-release-essentials.zip

# Whisper 语音转文字
# 如果不填写 WHISPER_COMMAND，并且 data/tools/whisper-python 已安装依赖，项目会优先使用内置 faster-whisper。
WHISPER_COMMAND=whisper
WHISPER_MODEL=small
UPLOAD_MAX_MB=300
